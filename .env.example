# LLM 调用配置（OpenAI 兼容接口）
# 例如：
#   - DeepSeek:     https://api.deepseek.com/v1 + sk-xxx + deepseek-v4-flash
#   - OpenAI:       https://api.openai.com/v1 + sk-xxx + gpt-4o-mini
#   - OpenClaw/本地: http://localhost:8000/v1 + (任意) + (模型名)
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=deepseek-v4-flash

# 资产库根目录（指向你的 Obsidian Vault）
INSIGHT_VAULT_PATH=/Users/vincent/Documents/knowledge_base

# 应用端口
PORT=4191

# 数据库位置
DATABASE_URL=file:./storage/insight.db
